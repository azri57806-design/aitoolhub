---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const navItems = [
  { href: `${base}`, label: '首页' },
  { href: `${base}ai-tools`, label: 'AI 工具榜单' },
  { href: `${base}tools`, label: '在线工具' },
  { href: `${base}about`, label: '关于' },
];
const isActive = (href) => {
  if (href === base) return pathname === href || pathname === href.replace(/\/$/, '');
  return pathname.startsWith(href);
};
---
<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={`${base}`} class="flex items-center gap-2 font-bold text-slate-900">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 text-white text-sm">AI</span>
      <span class="text-lg">AI 工具集</span>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`px-3 py-1.5 rounded-md text-sm transition ${
            isActive(item.href)
              ? 'bg-brand-50 text-brand-700 font-medium'
              : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <button id="menu-btn" class="md:hidden p-2 rounded-md text-slate-600 hover:bg-slate-100" aria-label="菜单">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white">
    <nav class="px-4 py-2 flex flex-col">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`px-3 py-2 rounded-md text-sm ${
            isActive(item.href)
              ? 'bg-brand-50 text-brand-700 font-medium'
              : 'text-slate-700 hover:bg-slate-100'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
<script is:inline>
  document.getElementById('menu-btn').addEventListener('click', () => {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
</script>
