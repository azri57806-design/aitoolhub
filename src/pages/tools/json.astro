---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="JSON 格式化" description="在线 JSON 美化、压缩、校验工具，支持错误定位。纯前端运行。">
  <section class="max-w-5xl mx-auto px-4 py-8">
    <a href={`${import.meta.env.BASE_URL}tools`} class="text-sm text-brand-600 hover:text-brand-700">← 返回工具列表</a>
    <h1 class="mt-2 text-3xl font-bold text-slate-900">🔧 JSON 格式化</h1>
    <p class="mt-1 text-slate-500">美化、压缩、校验 JSON，支持错误定位。</p>

    <div class="mt-6 flex flex-wrap gap-2">
      <button id="format-btn" class="px-4 py-1.5 bg-brand-600 text-white rounded text-sm hover:bg-brand-700">美化</button>
      <button id="minify-btn" class="px-4 py-1.5 border border-slate-300 rounded text-sm hover:bg-slate-50">压缩</button>
      <button id="copy-btn" class="px-4 py-1.5 border border-slate-300 rounded text-sm hover:bg-slate-50">复制</button>
      <button id="clear-btn" class="px-4 py-1.5 border border-slate-300 rounded text-sm hover:bg-slate-50">清空</button>
      <label class="flex items-center gap-1 text-sm text-slate-600 ml-auto">
        缩进：
        <select id="indent" class="border border-slate-300 rounded px-2 py-1 text-sm">
          <option value="2">2 空格</option>
          <option value="4">4 空格</option>
          <option value="tab">Tab</option>
        </select>
      </label>
    </div>

    <div class="mt-3 grid grid-cols-1 lg:grid-cols-2 gap-3">
      <textarea id="input" rows="16" placeholder='输入 JSON，例如：&#10;{"name":"AI工具集","tools":["ChatGPT","Claude"]}' class="w-full p-3 border border-slate-300 rounded-lg focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none font-mono text-sm resize-y"></textarea>
      <div class="relative">
        <textarea id="output" rows="16" readonly class="w-full p-3 border border-slate-300 rounded-lg bg-slate-50 font-mono text-sm resize-y" placeholder="输出结果..."></textarea>
      </div>
    </div>

    <div id="status" class="mt-3 text-sm"></div>
  </section>

  <script is:inline>
    const input = document.getElementById('input');
    const output = document.getElementById('output');
    const status = document.getElementById('status');
    const indentSel = document.getElementById('indent');

    function getIndent() {
      const v = indentSel.value;
      return v === 'tab' ? '\t' : parseInt(v);
    }

    function setStatus(msg, type) {
      status.textContent = msg;
      status.className = 'mt-3 text-sm ' + (type === 'error' ? 'text-rose-600' : type === 'ok' ? 'text-green-600' : 'text-slate-500');
    }

    document.getElementById('format-btn').addEventListener('click', () => {
      const text = input.value.trim();
      if (!text) return setStatus('请输入 JSON', 'error');
      try {
        const obj = JSON.parse(text);
        output.value = JSON.stringify(obj, null, getIndent());
        setStatus('✓ 格式化成功', 'ok');
      } catch (e) {
        output.value = '';
        setStatus('✗ ' + e.message, 'error');
      }
    });

    document.getElementById('minify-btn').addEventListener('click', () => {
      const text = input.value.trim();
      if (!text) return setStatus('请输入 JSON', 'error');
      try {
        const obj = JSON.parse(text);
        output.value = JSON.stringify(obj);
        setStatus('✓ 压缩成功', 'ok');
      } catch (e) {
        output.value = '';
        setStatus('✗ ' + e.message, 'error');
      }
    });

    document.getElementById('copy-btn').addEventListener('click', () => {
      if (!output.value) return;
      navigator.clipboard.writeText(output.value).then(() => {
        const btn = document.getElementById('copy-btn');
        const original = btn.textContent;
        btn.textContent = '已复制 ✓';
        setTimeout(() => btn.textContent = original, 1500);
      });
    });

    document.getElementById('clear-btn').addEventListener('click', () => {
      input.value = '';
      output.value = '';
      setStatus('', '');
      input.focus();
    });

    // 输入实时校验
    input.addEventListener('input', () => {
      const text = input.value.trim();
      if (!text) return setStatus('', '');
      try {
        JSON.parse(text);
        setStatus('✓ JSON 格式正确', 'ok');
      } catch (e) {
        setStatus('⚠ ' + e.message, 'error');
      }
    });
  </script>
</Layout>
