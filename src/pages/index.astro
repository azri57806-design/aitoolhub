---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import toolsData from '../data/tools.json';

const tools = toolsData.tools;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

// 按类别取热门工具
const categories = ['writing', 'image', 'code', 'video', 'audio'];
const featured = categories.map(cat => ({
  category: cat,
  items: tools.filter(t => t.category === cat).slice(0, 4),
}));

const categoryLabels = {
  writing: 'AI 写作',
  image: 'AI 绘图',
  code: 'AI 编程',
  video: 'AI 视频',
  audio: 'AI 音频',
  productivity: '效率工具',
  search: 'AI 搜索',
};

const categoryIcons = {
  writing: '✍️',
  image: '🎨',
  code: '💻',
  video: '🎬',
  audio: '🎵',
  productivity: '⚡',
  search: '🔍',
};

const onlineTools = [
  { name: '字数统计器', desc: '在线统计中英文字数、字符数、行数', href: `${base}tools/word-counter`, icon: '📝' },
  { name: 'UUID 生成器', desc: '批量生成 UUID v4，可复制使用', href: `${base}tools/uuid`, icon: '🆔' },
  { name: 'JSON 格式化', desc: 'JSON 美化、压缩、校验工具', href: `${base}tools/json`, icon: '🔧' },
  { name: 'Base64 编解码', desc: '文本与 Base64 互转工具', href: `${base}tools/base64`, icon: '🔐' },
];
---

<Layout title="">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-600 via-brand-700 to-brand-900 text-white">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-5xl font-bold leading-tight">
          发现最好用的 <span class="text-amber-300">AI 工具</span><br />
          与实用在线小工具
        </h1>
        <p class="mt-4 text-lg text-brand-100">
          每日更新的 AI 工具榜单，覆盖写作、绘图、编程、视频、音频全场景。所有在线工具免费、无需登录、纯前端运行。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${base}ai-tools`} class="inline-flex items-center gap-2 bg-white text-brand-700 px-5 py-2.5 rounded-lg font-medium hover:bg-amber-50 transition">
            浏览 AI 工具榜单 →
          </a>
          <a href={`${base}tools`} class="inline-flex items-center gap-2 bg-brand-500/30 border border-white/30 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-brand-500/50 transition">
            使用在线工具
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 在线工具 -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="flex items-end justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">🛠️ 实用在线工具</h2>
        <p class="text-slate-500 mt-1">免费、免登录、纯前端，数据不上传</p>
      </div>
      <a href={`${base}tools`} class="text-sm text-brand-600 hover:text-brand-700">全部 →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {onlineTools.map((tool) => (
        <a href={tool.href} class="group block bg-white rounded-xl border border-slate-200 p-5 hover:shadow-lg hover:border-brand-300 transition">
          <div class="text-3xl mb-3">{tool.icon}</div>
          <h3 class="font-semibold text-slate-900 group-hover:text-brand-600">{tool.name}</h3>
          <p class="mt-1 text-sm text-slate-500">{tool.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- AI 工具分类 -->
  {featured.map(({ category, items }) => (
    <section class="max-w-6xl mx-auto px-4 py-8">
      <div class="flex items-end justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">
          <span class="mr-2">{categoryIcons[category]}</span>
          {categoryLabels[category]}
        </h2>
        <a href={`${base}ai-tools?cat=${category}`} class="text-sm text-brand-600 hover:text-brand-700">查看全部 →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {items.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  ))}

  <!-- 数据说明 -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="bg-white rounded-xl border border-slate-200 p-6 md:p-8">
      <h2 class="text-xl font-bold text-slate-900 mb-4">📊 站点数据</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-brand-600">{tools.length}+</div>
          <div class="text-sm text-slate-500 mt-1">收录 AI 工具</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-600">7</div>
          <div class="text-sm text-slate-500 mt-1">工具分类</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-600">4</div>
          <div class="text-sm text-slate-500 mt-1">在线小工具</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-600">每日</div>
          <div class="text-sm text-slate-500 mt-1">自动更新</div>
        </div>
      </div>
    </div>
  </section>
</Layout>
