---
const { title, description } = Astro.props;
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteName = 'AI 工具集';
const fullTitle = title ? `${title} | ${siteName}` : `${siteName} — AI 工具导航与实用在线工具`;
const desc = description || '发现最好用的 AI 工具，提供实用在线小工具。每日更新 AI 工具榜单，覆盖写作、绘图、编程、视频、音频等场景。';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href={`${base}favicon.png`} type="image/png" sizes="64x64" />
  <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  <link rel="apple-touch-icon" href={`${base}logo-512.png`} />
  <link rel="apple-touch-icon" sizes="512x512" href={`${base}logo-512.png`} />
  <meta property="og:image" content={`${base}logo-512.png`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={`${base}logo-512.png`} />
  <title>{fullTitle}</title>
  <meta name="description" content={desc} />
  <meta name="generator" content={Astro.generator} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="zh_CN" />
  <link rel="canonical" href={Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname} />
  <link rel="sitemap" href={`${base}sitemap.xml`} />
</head>
<body class="min-h-screen flex flex-col bg-slate-50 text-slate-800 antialiased">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
